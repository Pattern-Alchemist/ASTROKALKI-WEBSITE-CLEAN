DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── EMAIL (required for /api/newsletter, /api/micro-reading, /api/bookings) ───
# Until these are set, every captured email is logged to dev.log instead of sent.
#
# Recommended: Gmail with an App Password (https://myaccount.google.com/apppasswords)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@astrokalki.com
#   SMTP_PASS=<16-char app password>
#
# Other providers:
#   Resend SMTP:    smtp.resend.com  / 465  / resend-XXXX
#   Brevo:          smtp-relay.brevo.com / 587
#   Mailgun:        smtp.mailgun.org / 587
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# "From" header for outgoing mail. If unset, falls back to SMTP_USER.
EMAIL_FROM=AstroKalki <no-reply@astrokalki.com>

# Where lead/booking/reading notifications are sent.
ADMIN_EMAIL=

# ─── SECURITY (required for admin auth + cron jobs) ───
# Generated by `openssl rand -base64 32`. Rotate by generating a new value
# and updating here; existing admin sessions are invalidated immediately.
ADMIN_PASSWORD=uYspYCF5UjcP3n+jwMcLXLGv0BM/Pel6ib03T7rj9no=

# Optional: separate secret for signing session cookies. If unset, falls
# back to ADMIN_PASSWORD. Set this if you want to rotate admin passwords
# without invalidating existing sessions.
# ADMIN_SESSION_SECRET=

# Cron job authentication — used by /api/cron/* endpoints.
CRON_SECRET=5dd791f5a905b2d2301a7c6844c94dda06f0360e7847d8382f0e0616bbcb91c3

# ─── STRIPE (membership checkout — upgrade) ───
# Get these from https://dashboard.stripe.com/test/apikeys
# Use test keys (pk_test_ / sk_test_) during development.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe dashboard (recurring prices for monthly/yearly)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
# The URL of your site (for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://astrokalki.com

# ─── NEXTAUTH (member portal — upgrade) ───
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=Kj8mR2pQ7vN4xW1yB6zA9cE5fH0jL3sT8uI7oP2qM4rS6tU0vX3wY5aZ7bC9dE1f
NEXTAUTH_URL=https://astrokalki.com

# ─── AVAILABILITY MINI-SERVICE (WebSocket — upgrade) ───
# Port for the real-time availability socket.io service
AVAILABILITY_PORT=3003
